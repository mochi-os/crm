    "deal": [
      {"id": "name", "name": "{labels.field.name}", "fieldtype": "text", "flags": "required,sort", "card": 1, "rank": 0, "rows": 1},
      {"id": "value", "name": "{labels.field.value}", "fieldtype": "text", "flags": "sort", "card": 1, "rank": 1, "rows": 1},
      {"id": "stage", "name": "{labels.field.stage}", "fieldtype": "enumerated", "flags": "required,sort", "card": 0, "rank": 2},
      {"id": "closedate", "name": "{labels.field.closedate}", "fieldtype": "date", "flags": "sort", "card": 0, "rank": 3},
      {"id": "owner", "name": "{labels.field.owner}", "fieldtype": "user", "flags": "", "card": 0, "rank": 4},
      {"id": "notes", "name": "{labels.field.notes}", "fieldtype": "text", "flags": "", "card": 0, "rank": 5, "rows": 3}
