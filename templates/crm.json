  "hierarchy": {
    "company": [""],
    "contact": ["company"],
    "deal": ["company", "contact"],
    "activity": ["company", "contact", "deal"]
  },
  "views": [
    {"id": "pipeline", "name": "{labels.view.pipeline}", "viewtype": "board", "columns": "stage", "fields": "name,value,closedate,owner", "classes": ["deal"]},
    {"id": "deals", "name": "{labels.view.deals}", "viewtype": "list", "fields": "name,value,stage,closedate,owner", "classes": ["deal"]},
    {"id": "contacts", "name": "{labels.view.contacts}", "viewtype": "list", "fields": "name,email,phone,jobtitle,owner", "classes": ["contact"]},
    {"id": "companies", "name": "{labels.view.companies}", "viewtype": "list", "fields": "name,domain,industry,size,owner", "classes": ["company"]},
    {"id": "activities", "name": "{labels.view.activities}", "viewtype": "list", "fields": "subject,type,due,completed,owner", "classes": ["activity"]}
  ]
