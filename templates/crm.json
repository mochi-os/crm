      {"id": "completed", "name": "{labels.field.completed}", "fieldtype": "enumerated", "flags": "sort", "card": 0, "rank": 3},
      {"id": "owner", "name": "{labels.field.owner}", "fieldtype": "user", "flags": "", "card": 0, "rank": 4},
      {"id": "notes", "name": "{labels.field.notes}", "fieldtype": "text", "flags": "", "card": 0, "rank": 5, "rows": 3}
