        {"id": "qualified", "name": "{labels.option.stage.qualified}", "colour": "#60a5fa", "rank": 1},
        {"id": "proposal", "name": "{labels.option.stage.proposal}", "colour": "#fbbf24", "rank": 2},
        {"id": "negotiation", "name": "{labels.option.stage.negotiation}", "colour": "#fb923c", "rank": 3},
        {"id": "won", "name": "{labels.option.stage.won}", "colour": "#4ade80", "rank": 4},
        {"id": "lost", "name": "{labels.option.stage.lost}", "colour": "#f87171", "rank": 5}
      ]
    },
    "activity": {
      "type": [
        {"id": "call", "name": "{labels.option.type.call}", "colour": "#60a5fa", "rank": 0},
        {"id": "email", "name": "{labels.option.type.email}", "colour": "#4ade80", "rank": 1},
        {"id": "meeting", "name": "{labels.option.type.meeting}", "colour": "#fbbf24", "rank": 2},
        {"id": "task", "name": "{labels.option.type.task}", "colour": "#a78bfa", "rank": 3}
