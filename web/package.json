{
  "name": "CRM",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "if [ \"$BUILD_LOCALES\" = en ]; then vite build; else tsc -b && vite build; fi",
    "lint": "eslint .",
    "preview": "vite preview",
    "knip": "pnpm -C ../../.. exec knip --workspace apps/crm/web",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "i18n:extract": "lingui extract",
    "i18n:check": "lingui extract --clean && git diff --exit-code -- src/locales || (echo \"\\033[1;31mCatalogs out of date \u2014 run pnpm i18n:extract and commit.\\033[0m\" && exit 1)"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@lingui/core": "^5.5.0",
    "@lingui/react": "^5.5.0",
    "@mochi/web": "workspace:*",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-router": "^1.132.47",
    "axios": "^1.12.2",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.545.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-hook-form": "^7.64.0",
    "tailwindcss": "^4.1.14",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@lingui/cli": "^5.5.0",
    "@lingui/swc-plugin": "^5.5.0",
    "@lingui/vite-plugin": "^5.5.0",
    "@tanstack/eslint-plugin-query": "^5.91.0",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@tanstack/react-router-devtools": "^1.132.51",
    "@tanstack/router-plugin": "^1.132.51",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^25.3.5",
    "@types/react": "19.2.1",
    "@types/react-dom": "19.2.1",
    "@vitejs/plugin-react-swc": "^4.1.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.37.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.23",
    "globals": "^16.4.0",
    "jsdom": "^27.4.0",
    "prettier": "^3.6.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.0",
    "vite": "^7.1.9",
    "vitest": "^4.0.18"
  }
}
